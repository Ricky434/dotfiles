{
	"layer": "top",
	"position": "bottom",
	"fixed-center": false,
	"reload_style_on_change": true,

	"modules-left": [
		"hyprland/workspaces",
		"niri/workspaces",
		"river/tags",
		"custom/arrow10",
		"hyprland/window",
		"niri/window",
		"river/window"
	],

	"modules-right": [
		"custom/arrow9",
		"wireplumber",
		"custom/arrow8",
		"network",
		"custom/arrow7",
		"memory",
		"custom/arrow6",
		"cpu",
		"custom/arrow5",
		"temperature",
		//"custom/arrow4",
		//"battery",
		"custom/arrow3",
		"hyprland/language",
		"custom/arrow2",
		"tray",
		"clock#date",
		"custom/arrow1",
		"clock#time",
		"custom/arrow11",
		"custom/power"
	],

	// Modules
	"custom/power": {
		"format": "вЏ»",
		"on-click": "powermenu",
		"tooltip": false
	},

	"battery": {
		"interval": 10,
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format-time": "{H}:{M:02}",
		"format": "{icon} {capacity}% ({time})",
		"format-charging": "пѓ§ {capacity}% ({time})",
		"format-charging-full": "пѓ§ {capacity}%",
		"format-full": "{icon} {capacity}%",
		"format-alt": "{icon} {power}W",
		"format-icons": [
			"п‰„",
			"п‰ѓ",
			"п‰‚",
			"п‰Ѓ",
			"п‰Ђ"
		],
		"tooltip": false
	},

	"clock#time": {
		"interval": 1,
		"format": "{:%H:%M}",
		"tooltip": true,
		"tooltip-format": "{:%H:%M:%S}",
		"timezone": "Europe/Rome"
	},

	"clock#date": {
		"interval": 20,
		"format": "{:%e %b %Y}",
		"tooltip": true,
		"tooltip-format": "<tt><small>{calendar}</small></tt>",
		"locale": "it_IT.UTF-8",
		"calendar": {
			"mode"          : "month",
			"mode-mon-col"  : 3,
			"weeks-pos"     : "left",
			"on-scroll"     : 1,
			"format": {
				"months":     "<span color='#6DC5D1'><b>{}</b></span>",
				"weeks":      "<span color='#FDE49E'><b>w{}</b></span>",
				"weekdays":   "<span color='#FEB941'><b>{}</b></span>",
				"today":      "<span color='#DD761C'><b><u>{}</u></b></span>"
			}
		},
		"actions":  {
			"on-click-right": "mode",
			"on-click-forward": "tz_up",
			"on-click-backward": "tz_down",
			"on-scroll-up": "shift_up",
			"on-scroll-down": "shift_down"
		},
		"on-click": "kitty -e calcurse"
	},

	"cpu": {
		"interval": 5,
		"tooltip": false,
		"format": "п‹› {usage}%",
		"format-alt": "п‹› {load}",
		"states": {
			"warning": 70,
			"critical": 90
		}
	},

	"hyprland/language": {
		"format": "п„њ {short} {variant}",
		"on-click": "hyprctl switchxkblayout keychron-keychron-q1-keyboard next",
		"keyboard-name": "keychron-keychron-q1-keyboard",
	},

	"memory": {
		"interval": 1,
		"format": "ої… {used}G/{total}G",
		"states": {
			"warning": 70,
			"critical": 90
		},
		"tooltip": false
	},

	"network": {
		"interval": 5,
		"family": "ipv4",
		"format-wifi": "у°–© {ifname} пЃў {bandwidthUpBytes} пЃЈ {bandwidthDownBytes}",
		"format-ethernet": "у°€Ђ {ifname} пЃў {bandwidthUpBytes} пЃЈ {bandwidthDownBytes}",
		"format-disconnected": "No connection",
		"format-alt": "п›ї {ipaddr}/{cidr}",
		"tooltip-format-wifi": "{essid}"
	},

	"hyprland/window": {
		"format": "{}",
		"max-length": 100,
		"tooltip": false,
		"separate-outputs": true,
		"on-click": "hyprctl dispatch layoutmsg cyclenext",
	},

	"hyprland/workspaces": {
		"on-scroll-up": "hyprctl dispatch workspace m+1",
		"on-scroll-down": "hyprctl dispatch workspace m-1",
		"format": "{name}"
	},

	"wireplumber": {
		"format": "{icon} {volume}%",
		//"format-bluetooth": "{icon}пЉ” {volume}%",
		"format-muted": "пЂ¦",
		"format-icons": ["пЂ§", "пЂЁ"],
		"scroll-step": 1,
		"on-click": "pulseaudio-control next-node",
		"on-click-middle": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
		"on-click-right": "pavucontrol",
		"tooltip": "{node_name}"
	},

	"temperature": {
		"hwmon-path": "/sys/class/hwmon/hwmon0/temp1_input",
		"critical-threshold": 90,
		"interval": 5,
		"format": "{icon} {temperatureC}В°",
		"format-icons": [
			"п‹‹",
			"п‹Љ",
			"п‹‰",
			"п‹€",
			"п‹‡"
		],
		"tooltip": false
	},

	"tray": {
